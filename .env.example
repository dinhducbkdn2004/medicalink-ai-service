# RabbitMQ (cùng hệ medicalink-microservice — worker + sự kiện bác sĩ)
# Worker chạy trong Docker + compose microservice: xem .env.docker.example (rabbitmq:5672, qdrant:6333)
RABBITMQ_URL=amqp://admin:admin123@localhost:5672/
# AI_RPC_QUEUE=ai_service_queue
# AI_EVENTS_QUEUE=ai_service_events_queue
# TOPIC_EXCHANGE=medicalink.topic

# OpenAI
OPENAI_API_KEY=sk-...

# Qdrant (Cloud: URL https://....cloud.qdrant.io:6333 + API key)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...
QDRANT_COLLECTION_NAME=doctor_profiles
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# LLM bước RAG: openai | gemini (khớp GOOGLE_GENAI_* của medicalink-microservice)
# LLM_PROVIDER=openai
# GOOGLE_GENAI_API_KEY=...
# GOOGLE_GENAI_MODEL=gemini-2.0-flash
# GOOGLE_GENAI_TIMEOUT=120000
# RAG_LLM_TEMPERATURE=0.2

# Đồng bộ batch qua HTTP public API (không cần JWT)
API_GATEWAY_BASE_URL=http://localhost:3000

# Hybrid Qdrant (dense OpenAI + sparse FastEmbed / BM25) + RRF
RAG_HYBRID_ENABLED=true
DENSE_VECTOR_NAME=dense
SPARSE_VECTOR_NAME=lexical
FASTEMBED_SPARSE_MODEL=Qdrant/bm25
RETRIEVAL_PREFETCH_LIMIT=40
RETRIEVAL_LLM_CONTEXT_MAX=24

# Re-ranking: none | lexical | flashrank
RAG_RERANK_MODE=flashrank
RAG_RERANK_LEXICAL_WEIGHT=0.2
FLASHRANK_MODEL=ms-marco-MiniLM-L-12-v2
FLASHRANK_CACHE_DIR=.cache/flashrank
RAG_RERANK_POOL=36
# Cộng điểm khi query có ý “giỏi/lâu năm/kinh nghiệm” (theo seniority_score trong payload)
# RAG_SENIORITY_BOOST_WEIGHT=0.18

# Một dòng JSON / request (để trống = tắt)
RAG_EVAL_LOG_PATH=./data/rag_eval.jsonl

# -----------------------------------------------------------------------------
# medicalink-ai-service — chạy TRONG Docker, cùng network với
# medicalink-microservice (development/docker-compose.yml).
#
# Cách dùng:
#   1. Ở repo microservice: pnpm dev-docker:up   (Postgres, Redis, RabbitMQ, Qdrant)
#   2. Copy file này thành .env (hoặc merge vào .env hiện có)
#   3. Ở repo ai-service:   docker compose -f compose.integrated.yaml up -d --build
#
# Hostname = TÊN SERVICE trong Compose (không phải container_name).
# -----------------------------------------------------------------------------

# RabbitMQ — service: rabbitmq
RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672/

# Qdrant — service: qdrant (Qdrant trong Docker local, không cần Qdrant Cloud)
QDRANT_URL=http://qdrant:6333
# Không bật API key trên Qdrant dev → để trống
QDRANT_API_KEY=

# OpenAI (embedding bắt buộc; chat nếu LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

QDRANT_COLLECTION_NAME=doctor_profiles
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Gateway để batch_sync gọi GET /api/doctors/profile/public
# • API Gateway chạy TRÊN MÁY HOST (pnpm start:gateway): dùng host.docker.internal
API_GATEWAY_BASE_URL=http://host.docker.internal:3000
# • Nếu toàn bộ stack deploy bằng deployment/* và gateway service tên api-gateway:
# API_GATEWAY_BASE_URL=http://api-gateway:3000

# LLM (tuỳ chọn gemini)
# LLM_PROVIDER=openai
# GOOGLE_GENAI_API_KEY=
# GOOGLE_GENAI_MODEL=gemini-2.0-flash

# Giữ nguyên các biến hybrid / rerank như .env.example nếu cần

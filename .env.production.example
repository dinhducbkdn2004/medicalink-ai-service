# =============================================================================
# MedicaLink AI worker — Production (Docker, cùng medicalink-network với backend)
# Sao chép: cp .env.production.example .env
# Trên server: đặt cạnh compose.integrated.yaml, compose đọc env_file: .env
#
# Điền __YOUR_*__ — không commit file .env chứa secret
# =============================================================================

# RabbitMQ — khớp RABBITMQ_URL / user-pass với backend production
RABBITMQ_URL=amqp://__YOUR_RABBITMQ_USER__:__YOUR_RABBITMQ_PASS__@rabbitmq:5672

# Tuỳ chọn (mặc định đã khớp worker)
# AI_RPC_QUEUE=ai_service_queue
# AI_EVENTS_QUEUE=ai_service_events_queue
# TOPIC_EXCHANGE=medicalink.topic

# --- OpenAI (bắt buộc cho embedding; cho chat nếu LLM_PROVIDER=openai) ---
OPENAI_API_KEY=__YOUR_OPENAI_API_KEY__

# Qdrant nội bộ (service: qdrant). Qdrant Cloud: https://xxx.cloud.qdrant.io:6333 + QDRANT_API_KEY
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

QDRANT_COLLECTION_NAME=doctor_profiles
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# LLM RAG: openai | gemini
LLM_PROVIDER=openai
GOOGLE_GENAI_API_KEY=__YOUR_GOOGLE_GENAI_KEY_IF_LLM_IS_GEMINI__
GOOGLE_GENAI_MODEL=gemini-2.0-flash
GOOGLE_GENAI_TIMEOUT=120000
RAG_LLM_TEMPERATURE=0.2

# Batch sync GET /api/doctors/profile/public — gateway trong cùng Docker network
API_GATEWAY_BASE_URL=http://api-gateway:3000

# Hybrid + rerank (giữ mặc định trừ khi bạn biết cần đổi)
RAG_HYBRID_ENABLED=true
DENSE_VECTOR_NAME=dense
SPARSE_VECTOR_NAME=lexical
FASTEMBED_SPARSE_MODEL=Qdrant/bm25
RETRIEVAL_PREFETCH_LIMIT=40
RETRIEVAL_LLM_CONTEXT_MAX=24

RAG_RERANK_MODE=flashrank
RAG_RERANK_LEXICAL_WEIGHT=0.2
FLASHRANK_MODEL=ms-marco-MiniLM-L-12-v2
FLASHRANK_CACHE_DIR=/app/.cache/flashrank
RAG_RERANK_POOL=36

# Để trống = tắt ghi eval. Trong container có volume ./data -> /app/data
# RAG_EVAL_LOG_PATH=/app/data/rag_eval.jsonl
